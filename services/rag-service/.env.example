# RAG Service Environment Variables
# Copy this file to .env and fill in your values

PORT=3001

# --- GROQ (LLM - Required) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Hugging Face (Free Cloud Embeddings - Required) ---
# Create a free account & token at https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_free_token_here

# --- Pinecone (Vector DB - Required) ---
# Will automatically create an index with 384 dimensions, metric: cosine
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=startup-platform

# --- Laravel App (for CORS whitelist) ---
LARAVEL_URL=http://127.0.0.1:8000
