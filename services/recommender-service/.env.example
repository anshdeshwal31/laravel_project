# Recommender Service Environment Variables
# Copy this file to .env and fill in your values

PORT=3002

# --- Hugging Face (Free Cloud Embeddings - Required) ---
# Create a free account & token at https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_free_token_here

# --- Laravel App (for CORS whitelist) ---
LARAVEL_URL=http://127.0.0.1:8000
